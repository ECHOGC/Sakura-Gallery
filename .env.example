# ==========================================
# Sakura+ Gallery 全局环境变量配置文件
# 请将此文件重命名为 .env 并修改下方密码
# ==========================================

# 1. 数据库安全配置 (必填)
# 推荐使用强密码，纯字母数字组合
DB_PASSWORD=SakuraGallery_YourPasswordHere

# 2. 网络端口配置 (如遇冲突可修改)
# MySQL 数据库外部映射端口 (默认 3306)
DB_PORT=3306

# 后端 API 接口运行端口 (默认 3001，前端代码中已写死指向 3001，如无必要请勿修改)
API_PORT=3001
